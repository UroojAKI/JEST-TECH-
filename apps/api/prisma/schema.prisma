generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////////

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum RoleType {
  SUPER_ADMIN
  ADMIN
  BRANCH_MANAGER
  TEAM_LEADER
  SALES_AGENT
  OPERATIONS
  UNDERWRITER
  CLAIMS_OFFICER
  FINANCE
  SUPPORT
  CUSTOMER
}

enum PermissionCategory {
  SYSTEM
  USER
  ROLE
  CONTACT
  ACCOUNT
  LEAD
  QUOTATION
  POLICY
  CLAIM
  REPORT
  DOCUMENT
  DASHBOARD
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PASSWORD_RESET
  APPROVE
  REJECT
}

enum ContactType {
  INDIVIDUAL
  CORPORATE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AccountType {
  INDIVIDUAL
  CORPORATE
  SME
  ENTERPRISE
  GOVERNMENT
}

enum CommunicationChannel {
  EMAIL
  PHONE
  SMS
  WHATSAPP
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum LeadSource {
  WEBSITE
  REFERRAL
  COLD_CALL
  SOCIAL_MEDIA
  CAMPAIGN
  PARTNER
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  TASK
}

enum ActivityStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum QuotationStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED_TO_POLICY
}

enum PolicyStatus {
  ACTIVE
  LAPSED
  CANCELLED
  PENDING_RENEWAL
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

//////////////////////////////////////////////////////////
// ROLES
//////////////////////////////////////////////////////////

model Role {
  id   String   @id @default(uuid())
  name String   @unique
  code String   @unique
  type RoleType @unique

  description String?

  isSystem Boolean @default(false)
  isActive Boolean @default(true)

  users       User[]
  permissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([code])
  @@map("roles")
}

//////////////////////////////////////////////////////////
// PERMISSIONS
//////////////////////////////////////////////////////////

model Permission {
  id String @id @default(uuid())

  name String @unique

  code String @unique

  description String?

  category PermissionCategory

  roles RolePermission[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("permissions")
}

//////////////////////////////////////////////////////////
// ROLE PERMISSION
//////////////////////////////////////////////////////////

model RolePermission {
  roleId String

  permissionId String

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

//////////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////////

model User {
  id String @id @default(uuid())

  employeeCode String? @unique

  firstName String

  lastName String

  email String @unique

  phone String?

  passwordHash String

  profileImage String?

  designation String?

  department String?

  status UserStatus @default(PENDING_VERIFICATION)

  isEmailVerified Boolean @default(false)

  isPhoneVerified Boolean @default(false)

  lastLoginAt DateTime?

  roleId String

  role Role @relation(fields: [roleId], references: [id])

  refreshTokens RefreshToken[]

  auditLogs AuditLog[]

  contactsCreated Contact[] @relation("ContactCreatedBy")

  contactsUpdated Contact[] @relation("ContactUpdatedBy")

  accountsCreated Account[] @relation("AccountCreatedBy")

  accountsUpdated Account[] @relation("AccountUpdatedBy")

  leadsAssigned Lead[] @relation("LeadAssignedTo")

  leadsCreated Lead[] @relation("LeadCreatedBy")

  leadsUpdated Lead[] @relation("LeadUpdatedBy")

  notesCreated Note[] @relation("NoteCreatedBy")

  activitiesCreated Activity[] @relation("ActivityCreatedBy")

  activitiesAssigned Activity[] @relation("ActivityAssignedTo")

  quotationsCreated Quotation[] @relation("QuotationCreatedBy")

  quotationsUpdated Quotation[] @relation("QuotationUpdatedBy")

  quotationVersionsCreated QuotationVersion[] @relation("QuotationVersionCreatedBy")

  quotationHistoriesCreated QuotationHistory[] @relation("QuotationHistoryCreatedBy")

  policiesCreated Policy[] @relation("PolicyCreatedBy")

  policiesUpdated Policy[] @relation("PolicyUpdatedBy")

  policyHistoriesCreated PolicyHistory[] @relation("PolicyHistoryCreatedBy")
  claimsCreated Claim[] @relation("ClaimCreatedBy")
  claimsUpdated Claim[] @relation("ClaimUpdatedBy")
  claimAssessments ClaimAssessment[] @relation("ClaimAssessor")
  claimReservesCreated ClaimReserve[] @relation("ClaimReserveCreatedBy")
  claimHistoriesCreated ClaimHistory[] @relation("ClaimHistoryCreatedBy")
  claimCommunicationsSent ClaimCommunication[] @relation("ClaimCommunicationSender")
  notifications           Notification[]
  notificationPreference  NotificationPreference?
  renewalTasks            RenewalTask[]
  uploadedDocuments       Document[] @relation("DocumentUploadedBy")
  documentAccessLogs      DocumentAccessLog[]
  submittedProposals      Proposal[] @relation("ProposalSubmittedBy")
  reviewedProposals       Proposal[] @relation("ProposalReviewedBy")
  approvedProposals       Proposal[] @relation("ProposalApprovedBy")
  requestedEndorsements   Endorsement[] @relation("EndorsementRequestedBy")
  approvedEndorsements    Endorsement[] @relation("EndorsementApprovedBy")
  proposalHistories       ProposalHistory[]
  endorsementHistories    EndorsementHistory[]
  savedReports            SavedReport[]         @relation("SavedReportCreatedBy")
  reportRuns              ReportRun[]           @relation("ReportRunTriggeredBy")
  kpiDefinitions          KpiDefinition[]       @relation("KpiDefinitionCreatedBy")

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  @@index([email])
  @@index([employeeCode])
  @@index([status])
  @@map("users")
}

//////////////////////////////////////////////////////////
// REFRESH TOKENS
//////////////////////////////////////////////////////////

model RefreshToken {
  id String @id @default(uuid())

  tokenHash String

  ipAddress String?

  userAgent String?

  expiresAt DateTime

  revokedAt DateTime?

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

//////////////////////////////////////////////////////////
// AUDIT LOG
//////////////////////////////////////////////////////////

model AuditLog {
  id String @id @default(uuid())

  action AuditAction

  entity String

  entityId String

  oldValue Json?

  newValue Json?

  ipAddress String?

  userAgent String?

  userId String?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([entity])
  @@index([entityId])
  @@index([action])
  @@map("audit_logs")
}

//////////////////////////////////////////////////////////
// CONTACTS
//////////////////////////////////////////////////////////

model Contact {
  id String @id @default(uuid())

  contactCode String @unique

  type ContactType

  firstName String

  middleName String?

  lastName String

  gender Gender?

  dateOfBirth DateTime?

  companyName String?

  email String?

  phone String

  alternatePhone String?

  whatsappNumber String?

  occupation String?

  panNumber String?

  aadhaarNumber String?

  gstNumber String?

  accountId String?

  account Account? @relation(fields: [accountId], references: [id])

  leads Lead[]

  quotations Quotation[]

  policies   Policy[]
  claims     Claim[]
  proposals  Proposal[]

  createdById String?

  updatedById String?

  createdBy User? @relation("ContactCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedBy User? @relation("ContactUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  @@index([phone])

  @@index([email])

  @@index([contactCode])

  @@index([accountId])

  @@map("contacts")
}

//////////////////////////////////////////////////////////
// ACCOUNTS
//////////////////////////////////////////////////////////

model Account {
  id String @id @default(uuid())

  accountCode String @unique

  name String

  type AccountType

  industry String?

  website String?

  email String?

  phone String?

  gstNumber String?

  panNumber String?

  annualRevenue Decimal?

  employeeCount Int?

  description String?

  status Boolean @default(true)

  preferredCommunication CommunicationChannel @default(EMAIL)

  preferredLanguage String?

  kycStatus KycStatus @default(PENDING)

  kycCompletedAt DateTime?

  contacts Contact[]

  leads Lead[]

  quotations Quotation[]

  policies   Policy[]
  claims     Claim[]

  createdById String?

  updatedById String?

  createdBy User? @relation("AccountCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedBy User? @relation("AccountUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  @@index([name])

  @@index([phone])

  @@index([email])

  @@index([accountCode])

  @@map("accounts")
}

//////////////////////////////////////////////////////////
// LEADS
//////////////////////////////////////////////////////////

model Lead {
  id          String     @id @default(uuid())
  leadCode    String     @unique
  title       String
  source      LeadSource @default(WEBSITE)
  status      LeadStatus @default(NEW)
  description String?

  contactId   String
  contact     Contact    @relation(fields: [contactId], references: [id])

  accountId   String?
  account     Account?   @relation(fields: [accountId], references: [id])

  assignedToId String?
  assignedTo   User?     @relation("LeadAssignedTo", fields: [assignedToId], references: [id])

  createdById String?
  updatedById String?
  createdBy   User?      @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?      @relation("LeadUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  notes       Note[]
  activities  Activity[]

  quotations  Quotation[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@index([leadCode])
  @@index([status])
  @@index([contactId])
  @@index([assignedToId])
  @@map("leads")
}

//////////////////////////////////////////////////////////
// NOTES
//////////////////////////////////////////////////////////

model Note {
  id          String    @id @default(uuid())
  content     String

  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?     @relation("NoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([leadId])
  @@map("notes")
}

//////////////////////////////////////////////////////////
// ACTIVITIES
//////////////////////////////////////////////////////////

model Activity {
  id           String         @id @default(uuid())
  type         ActivityType
  subject      String
  description  String?
  status       ActivityStatus @default(PENDING)
  dueDate      DateTime?
  completedAt  DateTime?

  leadId       String
  lead         Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   User?          @relation("ActivityAssignedTo", fields: [assignedToId], references: [id])

  createdById  String?
  createdBy    User?          @relation("ActivityCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  @@index([leadId])
  @@index([assignedToId])
  @@map("activities")
}

//////////////////////////////////////////////////////////
// QUOTATIONS
//////////////////////////////////////////////////////////

model Quotation {
  id            String          @id @default(uuid())
  quotationCode String          @unique
  title         String
  status        QuotationStatus @default(DRAFT)
  
  leadId        String?
  lead          Lead?           @relation(fields: [leadId], references: [id])
  
  contactId     String
  contact       Contact         @relation(fields: [contactId], references: [id])
  
  accountId     String?
  account       Account?        @relation(fields: [accountId], references: [id])
  
  insurerName   String
  productType   String
  sumInsured    Decimal
  basePremium   Decimal
  gstAmount     Decimal
  totalPremium  Decimal
  ncbPercentage Int             @default(0)
  discountAmount Decimal        @default(0)
  expiryDate    DateTime

  createdById   String?
  updatedById   String?
  createdBy     User?           @relation("QuotationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?           @relation("QuotationUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  versions      QuotationVersion[]
  addons        QuotationAddon[]
  discounts     QuotationDiscount[]
  histories     QuotationHistory[]
  documents     QuotationDocument[]

  policy        Policy?
  proposal      Proposal?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  @@index([quotationCode])
  @@index([status])
  @@map("quotations")
}

model QuotationVersion {
  id             String    @id @default(uuid())
  quotationId    String
  quotation      Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  versionNumber  Int
  sumInsured     Decimal
  basePremium    Decimal
  gstAmount      Decimal
  totalPremium   Decimal
  discountAmount Decimal
  metadata       Json?

  createdById    String?
  createdBy      User?     @relation("QuotationVersionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt      DateTime  @default(now())

  @@index([quotationId])
  @@map("quotation_versions")
}

model QuotationAddon {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  addonCode   String
  addonName   String
  premium     Decimal
  description String?

  @@index([quotationId])
  @@map("quotation_addons")
}

model QuotationDiscount {
  id           String    @id @default(uuid())
  quotationId  String
  quotation    Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  discountType String
  percentage   Decimal?
  amount       Decimal
  description  String?

  @@index([quotationId])
  @@map("quotation_discounts")
}

model QuotationComparison {
  id             String    @id @default(uuid())
  comparisonCode String    @unique
  leadId         String?
  metadata       Json?
  
  createdAt      DateTime  @default(now())

  @@index([comparisonCode])
  @@map("quotation_comparisons")
}

model QuotationHistory {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  status      String
  comments    String?
  
  createdById String?
  createdBy   User?     @relation("QuotationHistoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now())

  @@index([quotationId])
  @@map("quotation_histories")
}

model QuotationDocument {
  id           String    @id @default(uuid())
  quotationId  String
  quotation    Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  documentType String
  fileKey      String
  fileName     String
  fileSize     Int
  
  createdAt    DateTime  @default(now())

  @@index([quotationId])
  @@map("quotation_documents")
}

//////////////////////////////////////////////////////////
// POLICIES
//////////////////////////////////////////////////////////

model Policy {
  id             String       @id @default(uuid())
  policyNumber   String       @unique
  status         PolicyStatus @default(ACTIVE)

  quotationId    String       @unique
  quotation      Quotation    @relation(fields: [quotationId], references: [id])

  contactId      String
  contact        Contact      @relation(fields: [contactId], references: [id])

  accountId      String?
  account        Account?     @relation(fields: [accountId], references: [id])

  premiumAmount  Decimal
  effectiveDate  DateTime
  expiryDate     DateTime

  createdById    String?
  updatedById    String?
  createdBy      User?        @relation("PolicyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?        @relation("PolicyUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  members        PolicyMember[]
  nominees       PolicyNominee[]
  renewals       PolicyRenewal[]
  payments       PolicyPayment[]
  documents      PolicyDocument[]
  histories      PolicyHistory[]
  claims         Claim[]
  renewalTasks   RenewalTask[]
  proposalId     String?      @unique
  proposal       Proposal?    @relation(fields: [proposalId], references: [id])
  endorsements   Endorsement[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@index([policyNumber])
  @@index([status])
  @@map("policies")
}

model PolicyMember {
  id           String   @id @default(uuid())
  policyId     String
  policy       Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  relation     String
  dateOfBirth  DateTime

  @@index([policyId])
  @@map("policy_members")
}

model PolicyNominee {
  id           String   @id @default(uuid())
  policyId     String
  policy       Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  relation     String
  percentage   Decimal

  @@index([policyId])
  @@map("policy_nominees")
}

model PolicyRenewal {
  id             String    @id @default(uuid())
  policyId       String
  policy         Policy    @relation(fields: [policyId], references: [id], onDelete: Cascade)
  renewalNumber  Int
  previousExpiry DateTime
  newExpiry      DateTime
  premiumAmount  Decimal
  createdAt      DateTime  @default(now())

  @@index([policyId])
  @@map("policy_renewals")
}

model PolicyPayment {
  id            String        @id @default(uuid())
  policyId      String
  policy        Policy        @relation(fields: [policyId], references: [id], onDelete: Cascade)
  amount        Decimal
  paymentDate   DateTime      @default(now())
  transactionId String        @unique
  paymentMethod String
  status        PaymentStatus @default(SUCCESS)

  @@index([policyId])
  @@map("policy_payments")
}

model PolicyDocument {
  id           String   @id @default(uuid())
  policyId     String
  policy       Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  documentType String
  fileKey      String
  fileName     String
  fileSize     Int
  createdAt    DateTime @default(now())

  @@index([policyId])
  @@map("policy_documents")
}

model PolicyHistory {
  id          String   @id @default(uuid())
  policyId    String
  policy      Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  status      String
  comments    String?
  
  createdById String?
  createdBy   User?    @relation("PolicyHistoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())

  @@index([policyId])
  @@map("policy_histories")
}

//////////////////////////////////////////////////////////
// CLAIMS MANAGEMENT ENGINE
//////////////////////////////////////////////////////////

enum ClaimStatus {
  REPORTED
  REGISTERED
  SURVEYOR_ASSIGNED
  UNDER_ASSESSMENT
  APPROVED
  REJECTED
  PAYMENT_PENDING
  SETTLED
  CLOSED
}

enum ReserveType {
  INITIAL
  ADJUSTED
  RELEASED
}

model Claim {
  id             String          @id @default(uuid())
  claimNumber    String          @unique
  status         ClaimStatus     @default(REPORTED)
  
  policyId       String
  policy         Policy          @relation(fields: [policyId], references: [id])
  
  contactId      String
  contact        Contact         @relation(fields: [contactId], references: [id])
  
  accountId      String?
  account        Account?        @relation(fields: [accountId], references: [id])
  
  incidentDate   DateTime
  reportedDate   DateTime        @default(now())
  description    String
  claimAmount    Decimal
  approvedAmount Decimal?
  
  surveyorName   String?
  surveyorDetails String?

  createdById    String?
  updatedById    String?
  createdBy      User?           @relation("ClaimCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?           @relation("ClaimUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  documents      ClaimDocument[]
  assessments    ClaimAssessment[]
  payments       ClaimPayment[]
  reserves       ClaimReserve[]
  histories      ClaimHistory[]
  communications ClaimCommunication[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  @@index([claimNumber])
  @@index([status])
  @@index([policyId])
  @@map("claims")
}

model ClaimDocument {
  id           String    @id @default(uuid())
  claimId      String
  claim        Claim     @relation(fields: [claimId], references: [id], onDelete: Cascade)
  documentType String
  fileKey      String
  fileName     String
  fileSize     Int
  uploadedById String?
  
  createdAt    DateTime  @default(now())

  @@index([claimId])
  @@map("claim_documents")
}

model ClaimAssessment {
  id             String    @id @default(uuid())
  claimId        String
  claim          Claim     @relation(fields: [claimId], references: [id], onDelete: Cascade)
  assessorId     String?
  assessor       User?     @relation("ClaimAssessor", fields: [assessorId], references: [id], onDelete: SetNull)
  assessmentDate DateTime  @default(now())
  findings       String
  estimatedLoss  Decimal
  approvedAmount Decimal
  status         String    // e.g. PENDING, COMPLETED, REJECTED
  
  createdAt      DateTime  @default(now())

  @@index([claimId])
  @@map("claim_assessments")
}

model ClaimPayment {
  id             String        @id @default(uuid())
  claimId        String
  claim          Claim         @relation(fields: [claimId], references: [id], onDelete: Cascade)
  amount         Decimal
  paymentDate    DateTime      @default(now())
  transactionId  String        @unique
  paymentMethod  String
  status         PaymentStatus @default(PENDING)
  recipientDetails String
  
  createdAt      DateTime      @default(now())

  @@index([claimId])
  @@map("claim_payments")
}

model ClaimReserve {
  id           String      @id @default(uuid())
  claimId      String
  claim        Claim       @relation(fields: [claimId], references: [id], onDelete: Cascade)
  amount       Decimal
  type         ReserveType @default(INITIAL)
  comments     String?
  createdById  String?
  createdBy    User?       @relation("ClaimReserveCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  
  createdAt    DateTime    @default(now())

  @@index([claimId])
  @@map("claim_reserves")
}

model ClaimHistory {
  id          String      @id @default(uuid())
  claimId     String
  claim       Claim       @relation(fields: [claimId], references: [id], onDelete: Cascade)
  status      ClaimStatus
  action      String
  comments    String?
  createdById String?
  createdBy   User?       @relation("ClaimHistoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  
  createdAt   DateTime    @default(now())

  @@index([claimId])
  @@map("claim_histories")
}

model ClaimCommunication {
  id          String               @id @default(uuid())
  claimId     String
  claim       Claim                @relation(fields: [claimId], references: [id], onDelete: Cascade)
  senderId    String?
  sender      User?                @relation("ClaimCommunicationSender", fields: [senderId], references: [id], onDelete: SetNull)
  recipient   String
  channel     CommunicationChannel
  subject     String?
  body        String
  sentAt      DateTime             @default(now())

  @@index([claimId])
  @@map("claim_communications")
}

//////////////////////////////////////////////////////////
// NOTIFICATIONS & RENEWALS
//////////////////////////////////////////////////////////

enum NotificationType {
  SYSTEM
  LEAD_ASSIGNED
  LEAD_UPDATED
  FOLLOW_UP_DUE
  QUOTATION_CREATED
  QUOTATION_APPROVED
  QUOTATION_REJECTED
  POLICY_ISSUED
  POLICY_CANCELLED
  POLICY_RENEWAL_45
  POLICY_RENEWAL_30
  POLICY_RENEWAL_20
  CLAIM_REGISTERED
  CLAIM_ASSIGNED
  CLAIM_APPROVED
  CLAIM_SETTLED
  DOCUMENT_UPLOADED
  ENDORSEMENT_APPROVED
}

enum NotificationPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum RenewalTaskStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Notification {
  id          String               @id @default(uuid())
  title       String
  message     String
  type        NotificationType
  priority    NotificationPriority @default(MEDIUM)
  userId      String
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityId    String?
  entityType  String?
  actionUrl   String?
  icon        String?
  color       String?
  expiresAt   DateTime?
  isRead      Boolean              @default(false)
  readAt      DateTime?
  createdAt   DateTime             @default(now())
  histories   NotificationHistory[]

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model NotificationTemplate {
  id        String           @id @default(uuid())
  name      String           @unique
  type      NotificationType
  channel   String           @default("IN_APP")
  subject   String?
  body      String
  variables Json?
  active    Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@map("notification_templates")
}

model NotificationPreference {
  id         String  @id @default(uuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  inApp      Boolean @default(true)
  email      Boolean @default(false)
  sms        Boolean @default(false)
  whatsapp   Boolean @default(false)
  renewals   Boolean @default(true)
  claims     Boolean @default(true)
  policies   Boolean @default(true)
  leads      Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("notification_preferences")
}

model NotificationHistory {
  id             String             @id @default(uuid())
  notificationId String
  notification   Notification       @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  status         NotificationStatus @default(SENT)
  channel        String             @default("IN_APP")
  sentAt         DateTime           @default(now())
  failureReason  String?

  @@index([notificationId])
  @@map("notification_histories")
}

model RenewalTask {
  id        String            @id @default(uuid())
  policyId  String
  policy    Policy            @relation(fields: [policyId], references: [id], onDelete: Cascade)
  agentId   String
  agent     User              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  dueDate   DateTime
  status    RenewalTaskStatus @default(PENDING)
  priority  NotificationPriority @default(MEDIUM)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([policyId])
  @@index([agentId])
  @@map("renewal_tasks")
}

//////////////////////////////////////////////////////////
// SECURE DOCUMENT MANAGEMENT
//////////////////////////////////////////////////////////

enum DocumentVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum DocumentStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum DocumentAccessAction {
  VIEW
  DOWNLOAD
  DELETE
  RESTORE
}

model Document {
  id                 String                     @id @default(uuid())
  documentNumber     String                     @unique
  name               String
  originalFileName   String
  mimeType           String
  size               Int
  storageKey         String
  storageProvider    String
  hash               String
  entityType         String
  entityId           String
  uploadedById       String
  uploadedBy         User                       @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])
  status             DocumentStatus             @default(ACTIVE)
  version            Int                        @default(1)
  verificationStatus DocumentVerificationStatus @default(PENDING)
  expiryDate         DateTime?
  tags               String[]                   @default([])
  metadata           Json?
  
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  deletedAt          DateTime?

  versions           DocumentVersion[]
  accessLogs         DocumentAccessLog[]
  proposalDocuments   ProposalDocument[]
  endorsementDocuments EndorsementDocument[]

  @@index([entityType, entityId])
  @@index([uploadedById])
  @@index([documentNumber])
  @@map("documents")
}

model DocumentVersion {
  id               String   @id @default(uuid())
  documentId       String
  document         Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version          Int
  storageKey       String
  originalFileName String
  size             Int
  hash             String
  uploadedAt       DateTime @default(now())

  @@index([documentId])
  @@map("document_versions")
}

model DocumentAccessLog {
  id         String               @id @default(uuid())
  documentId String
  document   Document             @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     DocumentAccessAction
  ipAddress  String?
  createdAt  DateTime             @default(now())

  @@index([documentId])
  @@index([userId])
  @@map("document_access_logs")
}

//////////////////////////////////////////////////////////
// MOTOR ADMINISTRATION & RATING RULES
//////////////////////////////////////////////////////////

enum VehicleType {
  TWO_WHEELER
  FOUR_WHEELER
  COMMERCIAL
}

enum FuelType {
  PETROL
  DIESEL
  CNG
  ELECTRIC
  HYBRID
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
}

enum RatingRuleType {
  BASE_RATE
  AGE_LOADING
  NCB_DISCOUNT
  OD_DISCOUNT
  ADDON_RATE
  TAX_RATE
}

enum ProductType {
  THIRD_PARTY
  COMPREHENSIVE
  ZERO_DEP
  OWN_DAMAGE
  COMMERCIAL
}

model VehicleManufacturer {
  id        String         @id @default(uuid())
  name      String         @unique
  code      String         @unique
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  models    VehicleModel[]

  @@map("vehicle_manufacturers")
}

model VehicleModel {
  id             String              @id @default(uuid())
  manufacturerId String
  manufacturer   VehicleManufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
  name           String
  code           String              @unique
  vehicleType    VehicleType         @default(FOUR_WHEELER)
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  variants       VehicleVariant[]

  @@index([manufacturerId])
  @@map("vehicle_models")
}

model VehicleVariant {
  id               String           @id @default(uuid())
  modelId          String
  model            VehicleModel     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  name             String
  code             String           @unique
  fuelType         FuelType         @default(PETROL)
  transmissionType TransmissionType @default(MANUAL)
  engineCapacity   Int
  exShowroomPrice  Decimal
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([modelId])
  @@map("vehicle_variants")
}

model Insurer {
  id             String       @id @default(uuid())
  name           String       @unique
  code           String       @unique
  rating         Decimal?
  isActive       Boolean      @default(true)
  contactDetails Json?
  logoUrl        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  rules          RatingRule[]

  @@map("insurers")
}

model Product {
  id                  String       @id @default(uuid())
  name                String
  code                String       @unique
  type                ProductType
  baseCommissionRate  Decimal
  description         String?
  isActive            Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  rules               RatingRule[]

  @@map("products")
}

model RatingRule {
  id                  String         @id @default(uuid())
  productId           String
  product             Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  insurerId           String
  insurer             Insurer        @relation(fields: [insurerId], references: [id], onDelete: Cascade)
  ruleName            String
  ruleType            RatingRuleType
  eligibilityCriteria Json
  formulaOrRate       Json
  priority            Int            @default(0)
  isActive            Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([productId])
  @@index([insurerId])
  @@map("rating_rules")
}

//////////////////////////////////////////////////////////
// PROPOSALS & UNDERWRITING
//////////////////////////////////////////////////////////

enum ProposalStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  DOCUMENT_PENDING
  APPROVED
  REJECTED
  POLICY_ISSUED
}

model Proposal {
  id             String             @id @default(uuid())
  proposalNumber String             @unique
  quotationId    String             @unique
  quotation      Quotation          @relation(fields: [quotationId], references: [id])
  contactId      String
  contact        Contact            @relation(fields: [contactId], references: [id])
  status         ProposalStatus     @default(DRAFT)
  remarks        String?
  submittedById  String
  submittedBy    User               @relation("ProposalSubmittedBy", fields: [submittedById], references: [id])
  reviewedById   String?
  reviewedBy     User?              @relation("ProposalReviewedBy", fields: [reviewedById], references: [id])
  approvedById   String?
  approvedBy     User?              @relation("ProposalApprovedBy", fields: [approvedById], references: [id])
  rejectedReason String?
  submittedAt    DateTime?
  reviewedAt     DateTime?
  approvedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  documents      ProposalDocument[]
  histories      ProposalHistory[]
  policy         Policy?

  @@index([quotationId])
  @@index([contactId])
  @@index([submittedById])
  @@map("proposals")
}

model ProposalDocument {
  id         String   @id @default(uuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  mandatory  Boolean  @default(true)
  verified   Boolean  @default(false)
  remarks    String?

  @@index([proposalId])
  @@index([documentId])
  @@map("proposal_documents")
}

model ProposalHistory {
  id            String         @id @default(uuid())
  proposalId    String
  proposal      Proposal       @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  status        ProposalStatus
  comments      String?
  performedById String
  performedBy   User           @relation(fields: [performedById], references: [id])
  createdAt     DateTime       @default(now())

  @@index([proposalId])
  @@index([performedById])
  @@map("proposal_histories")
}

//////////////////////////////////////////////////////////
// ENDORSEMENTS & ALTERATIONS
//////////////////////////////////////////////////////////

enum EndorsementType {
  ADDRESS_CHANGE
  OWNER_TRANSFER
  NOMINEE_CHANGE
}

enum EndorsementStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  COMPLETED
}

model Endorsement {
  id                String            @id @default(uuid())
  endorsementNumber String            @unique
  policyId          String
  policy            Policy            @relation(fields: [policyId], references: [id], onDelete: Cascade)
  type              EndorsementType
  status            EndorsementStatus @default(REQUESTED)
  requestedById     String
  requestedBy       User              @relation("EndorsementRequestedBy", fields: [requestedById], references: [id])
  approvedById      String?
  approvedBy        User?             @relation("EndorsementApprovedBy", fields: [approvedById], references: [id])
  reason            String
  effectiveDate     DateTime          @default(now())
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  documents         EndorsementDocument[]
  histories         EndorsementHistory[]

  @@index([policyId])
  @@index([requestedById])
  @@map("endorsements")
}

model EndorsementDocument {
  id            String      @id @default(uuid())
  endorsementId String
  endorsement   Endorsement @relation(fields: [endorsementId], references: [id], onDelete: Cascade)
  documentId    String
  document      Document    @relation(fields: [documentId], references: [id])

  @@index([endorsementId])
  @@index([documentId])
  @@map("endorsement_documents")
}

model EndorsementHistory {
  id            String            @id @default(uuid())
  endorsementId String
  endorsement   Endorsement       @relation(fields: [endorsementId], references: [id], onDelete: Cascade)
  status        EndorsementStatus
  comments      String?
  performedById String
  performedBy   User              @relation(fields: [performedById], references: [id])
  createdAt     DateTime          @default(now())

  @@index([endorsementId])
  @@index([performedById])
  @@map("endorsement_histories")
}

//////////////////////////////////////////////////////////
// REPORTING, BI & DATA WAREHOUSE
//////////////////////////////////////////////////////////

enum ReportRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum KpiUnit {
  PERCENTAGE
  CURRENCY
  COUNT
  RATIO
  DAYS
}

enum ReportCategory {
  CRM
  SALES
  CLAIMS
  RENEWALS
  FINANCE
  OPERATIONS
  COMPLIANCE
}

model SavedReport {
  id          String         @id @default(uuid())
  name        String
  description String?
  category    ReportCategory
  dataSource  String         // contacts | leads | policies | claims | renewals | revenue
  columns     Json           // Array of column definition objects
  filters     Json           // Array of filter definition objects
  sortBy      String?
  sortDir     String?        @default("asc")
  isBuiltIn   Boolean        @default(false)
  isActive    Boolean        @default(true)

  createdById String
  createdBy   User           @relation("SavedReportCreatedBy", fields: [createdById], references: [id])

  runs        ReportRun[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([createdById])
  @@index([category])
  @@map("saved_reports")
}

model ReportRun {
  id            String          @id @default(uuid())
  savedReportId String
  savedReport   SavedReport     @relation(fields: [savedReportId], references: [id], onDelete: Cascade)
  status        ReportRunStatus @default(PENDING)
  rowCount      Int?
  exportPath    String?
  errorMessage  String?
  appliedFilters Json?

  triggeredById String?
  triggeredBy   User?   @relation("ReportRunTriggeredBy", fields: [triggeredById], references: [id], onDelete: SetNull)

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([savedReportId])
  @@index([status])
  @@map("report_runs")
}

model KpiDefinition {
  id          String   @id @default(uuid())
  name        String
  key         String   @unique
  description String?
  formula     String   // e.g. "policies_issued / leads_created * 100"
  category    String   // revenue | sales | claims | renewals | operations
  unit        KpiUnit  @default(COUNT)
  isActive    Boolean  @default(true)
  displayOrder Int     @default(0)

  createdById String?
  createdBy   User?   @relation("KpiDefinitionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@map("kpi_definitions")
}
