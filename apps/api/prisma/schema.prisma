generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////////

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum RoleType {
  SUPER_ADMIN
  ADMIN
  BRANCH_MANAGER
  TEAM_LEADER
  SALES_AGENT
  OPERATIONS
  UNDERWRITER
  CLAIMS_OFFICER
  FINANCE
  SUPPORT
  CUSTOMER
}

enum PermissionCategory {
  SYSTEM
  USER
  ROLE
  CONTACT
  ACCOUNT
  LEAD
  QUOTATION
  POLICY
  CLAIM
  REPORT
  WORKFLOW
  DOCUMENT
  DASHBOARD
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PASSWORD_RESET
  APPROVE
  REJECT
}

enum ContactType {
  INDIVIDUAL
  CORPORATE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AccountType {
  INDIVIDUAL
  CORPORATE
  SME
  ENTERPRISE
  GOVERNMENT
}

enum CommunicationChannel {
  EMAIL
  PHONE
  SMS
  WHATSAPP
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum LeadSource {
  WEBSITE
  REFERRAL
  COLD_CALL
  SOCIAL_MEDIA
  CAMPAIGN
  PARTNER
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  TASK
}

enum ActivityStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum QuotationStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED_TO_POLICY
}

enum PolicyStatus {
  ACTIVE
  LAPSED
  CANCELLED
  PENDING_RENEWAL
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

//////////////////////////////////////////////////////////
// ROLES
//////////////////////////////////////////////////////////

model Role {
  id   String   @id @default(uuid())
  name String   @unique
  code String   @unique
  type RoleType @unique

  description String?

  isSystem Boolean @default(false)
  isActive Boolean @default(true)

  users       User[]
  permissions RolePermission[]
  workflowAssignments WorkflowAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([code])
  @@map("roles")
}

//////////////////////////////////////////////////////////
// PERMISSIONS
//////////////////////////////////////////////////////////

model Permission {
  id String @id @default(uuid())

  name String @unique

  code String @unique

  description String?

  category PermissionCategory

  roles RolePermission[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("permissions")
}

//////////////////////////////////////////////////////////
// ROLE PERMISSION
//////////////////////////////////////////////////////////

model RolePermission {
  roleId String

  permissionId String

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

//////////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////////

model User {
  id String @id @default(uuid())

  employeeCode String? @unique

  firstName String

  lastName String

  email String @unique

  phone String?

  passwordHash String

  profileImage String?

  designation String?

  legacyDepartment String?

  status UserStatus @default(PENDING_VERIFICATION)

  isEmailVerified Boolean @default(false)

  isPhoneVerified Boolean @default(false)

  lastLoginAt DateTime?

  teamId String?
  departmentId String?
  branchId String?

  team Team? @relation(fields: [teamId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])

  queueMembers QueueMember[]
  commissions Commission[]

  roleId String

  role Role @relation(fields: [roleId], references: [id])

  refreshTokens RefreshToken[]

  auditLogs AuditLog[]

  contactsCreated Contact[] @relation("ContactCreatedBy")

  contactsUpdated Contact[] @relation("ContactUpdatedBy")

  accountsCreated Account[] @relation("AccountCreatedBy")

  accountsUpdated Account[] @relation("AccountUpdatedBy")

  leadsAssigned Lead[] @relation("LeadAssignedTo")

  leadsCreated Lead[] @relation("LeadCreatedBy")

  leadsUpdated Lead[] @relation("LeadUpdatedBy")

  notesCreated Note[] @relation("NoteCreatedBy")

  activitiesCreated Activity[] @relation("ActivityCreatedBy")

  activitiesAssigned Activity[] @relation("ActivityAssignedTo")

  quotationsCreated Quotation[] @relation("QuotationCreatedBy")

  quotationsUpdated Quotation[] @relation("QuotationUpdatedBy")

  quotationVersionsCreated QuotationVersion[] @relation("QuotationVersionCreatedBy")

  quotationHistoriesCreated QuotationHistory[] @relation("QuotationHistoryCreatedBy")

  policiesCreated Policy[] @relation("PolicyCreatedBy")

  policiesUpdated Policy[] @relation("PolicyUpdatedBy")

  policyHistoriesCreated PolicyHistory[] @relation("PolicyHistoryCreatedBy")
  claimsCreated Claim[] @relation("ClaimCreatedBy")
  claimsUpdated Claim[] @relation("ClaimUpdatedBy")
  claimAssessments ClaimAssessment[] @relation("ClaimAssessor")
  claimReservesCreated ClaimReserve[] @relation("ClaimReserveCreatedBy")
  claimHistoriesCreated ClaimHistory[] @relation("ClaimHistoryCreatedBy")
  claimCommunicationsSent ClaimCommunication[] @relation("ClaimCommunicationSender")
  notifications           Notification[]
  notificationPreference  NotificationPreference?
  renewalTasks            RenewalTask[]
  uploadedDocuments       Document[] @relation("DocumentUploadedBy")
  documentAccessLogs      DocumentAccessLog[]
  submittedProposals      Proposal[] @relation("ProposalSubmittedBy")
  reviewedProposals       Proposal[] @relation("ProposalReviewedBy")
  approvedProposals       Proposal[] @relation("ProposalApprovedBy")
  requestedEndorsements   Endorsement[] @relation("EndorsementRequestedBy")
  approvedEndorsements    Endorsement[] @relation("EndorsementApprovedBy")
  proposalHistories       ProposalHistory[]
  endorsementHistories    EndorsementHistory[]
  savedReports            SavedReport[]         @relation("SavedReportCreatedBy")
  reportRuns              ReportRun[]           @relation("ReportRunTriggeredBy")
  kpiDefinitions          KpiDefinition[]       @relation("KpiDefinitionCreatedBy")
  reportsCreated          Report[]              @relation("ReportCreatedBy")
  reportsUpdated          Report[]              @relation("ReportUpdatedBy")
  reportExecutionsRequested ReportExecution[]     @relation("ReportExecutionRequestedBy")
  savedFilters              SavedFilter[]
  favoriteReports           FavoriteReport[]
  workflowHistories         WorkflowHistory[]
  workflowAssignments       WorkflowAssignment[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  @@index([email])
  @@index([employeeCode])
  @@index([status])
  @@map("users")
}

//////////////////////////////////////////////////////////
// REFRESH TOKENS
//////////////////////////////////////////////////////////

model RefreshToken {
  id String @id @default(uuid())

  tokenHash String

  ipAddress String?

  userAgent String?

  expiresAt DateTime

  revokedAt DateTime?

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

//////////////////////////////////////////////////////////
// AUDIT LOG
//////////////////////////////////////////////////////////

model AuditLog {
  id String @id @default(uuid())

  action AuditAction

  entity String

  entityId String

  oldValue Json?

  newValue Json?

  ipAddress String?

  userAgent String?

  userId String?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  correlationId String?

  module String?

  createdAt DateTime @default(now())

  @@index([entity])
  @@index([entityId])
  @@index([action])
  @@index([entity, entityId])
  @@map("audit_logs")
}

//////////////////////////////////////////////////////////
// CONTACTS
//////////////////////////////////////////////////////////

model Contact {
  id String @id @default(uuid())

  contactCode String @unique

  type ContactType

  firstName String

  middleName String?

  lastName String

  gender Gender?

  dateOfBirth DateTime?

  companyName String?

  email String?

  phone String

  alternatePhone String?

  whatsappNumber String?

  occupation String?

  panNumber String?

  aadhaarNumber String?

  gstNumber String?

  accountId String?

  account Account? @relation(fields: [accountId], references: [id])

  leads Lead[]

  quotations Quotation[]

  policies   Policy[]
  claims     Claim[]
  proposals  Proposal[]

  createdById String?

  updatedById String?

  createdBy User? @relation("ContactCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedBy User? @relation("ContactUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  analytics CustomerAnalytics?
  communications CommunicationLog[]
  familyMembers FamilyMember[]
  vehicles VehicleAsset[]

  @@index([phone])

  @@index([email])

  @@index([contactCode])

  @@index([accountId])

  @@map("contacts")
}

//////////////////////////////////////////////////////////
// ACCOUNTS
//////////////////////////////////////////////////////////

model Account {
  id String @id @default(uuid())

  accountCode String @unique

  name String

  type AccountType

  industry String?

  website String?

  email String?

  phone String?

  gstNumber String?

  panNumber String?

  annualRevenue Decimal?

  employeeCount Int?

  description String?

  status Boolean @default(true)

  preferredCommunication CommunicationChannel @default(EMAIL)

  preferredLanguage String?

  kycStatus KycStatus @default(PENDING)

  kycCompletedAt DateTime?

  contacts Contact[]

  leads Lead[]

  quotations Quotation[]

  policies   Policy[]
  claims     Claim[]

  createdById String?

  updatedById String?

  createdBy User? @relation("AccountCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedBy User? @relation("AccountUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  @@index([name])

  @@index([phone])

  @@index([email])

  @@index([accountCode])

  @@map("accounts")
}

//////////////////////////////////////////////////////////
// LEADS
//////////////////////////////////////////////////////////

model Lead {
  id          String     @id @default(uuid())
  leadCode    String     @unique
  title       String
  source      LeadSource @default(WEBSITE)
  status      LeadStatus @default(NEW)
  description String?

  contactId   String
  contact     Contact    @relation(fields: [contactId], references: [id])

  accountId   String?
  account     Account?   @relation(fields: [accountId], references: [id])

  assignedToId String?
  assignedTo   User?     @relation("LeadAssignedTo", fields: [assignedToId], references: [id])

  createdById String?
  updatedById String?
  createdBy   User?      @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?      @relation("LeadUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  score           Int       @default(0)
  priority        String?   // 'HIGH', 'MEDIUM', 'LOW'
  firstResponseAt DateTime?
  slaStatus       String?   // 'IN_SLA', 'BREACHED', 'COMPLETED'
  isDuplicate     Boolean   @default(false)
  duplicateOfId   String?
  duplicateOf     Lead?     @relation("LeadDuplicates", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates      Lead[]    @relation("LeadDuplicates")


  notes       Note[]
  activities  Activity[]

  quotations  Quotation[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  version     Int        @default(1)

  @@index([leadCode])
  @@index([status])
  @@index([contactId])
  @@index([assignedToId])
  @@map("leads")
}

//////////////////////////////////////////////////////////
// NOTES
//////////////////////////////////////////////////////////

model Note {
  id          String    @id @default(uuid())
  content     String

  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?     @relation("NoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([leadId])
  @@map("notes")
}

//////////////////////////////////////////////////////////
// ACTIVITIES
//////////////////////////////////////////////////////////

model Activity {
  id           String         @id @default(uuid())
  type         ActivityType
  subject      String
  description  String?
  status       ActivityStatus @default(PENDING)
  dueDate      DateTime?
  completedAt  DateTime?

  leadId       String
  lead         Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   User?          @relation("ActivityAssignedTo", fields: [assignedToId], references: [id])

  createdById  String?
  createdBy    User?          @relation("ActivityCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  @@index([leadId])
  @@index([assignedToId])
  @@map("activities")
}

//////////////////////////////////////////////////////////
// QUOTATIONS
//////////////////////////////////////////////////////////

model Quotation {
  id            String          @id @default(uuid())
  quotationCode String          @unique
  title         String
  status        QuotationStatus @default(DRAFT)
  
  leadId        String?
  lead          Lead?           @relation(fields: [leadId], references: [id])
  
  contactId     String
  contact       Contact         @relation(fields: [contactId], references: [id])
  
  accountId     String?
  account       Account?        @relation(fields: [accountId], references: [id])
  
  insurerName   String
  productType   String
  sumInsured    Decimal
  basePremium   Decimal
  gstAmount     Decimal
  totalPremium  Decimal
  ncbPercentage Int             @default(0)
  discountAmount Decimal        @default(0)
  expiryDate    DateTime

  createdById   String?
  updatedById   String?
  createdBy     User?           @relation("QuotationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?           @relation("QuotationUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  versions      QuotationVersion[]
  addons        QuotationAddon[]
  discounts     QuotationDiscount[]
  histories     QuotationHistory[]
  documents     QuotationDocument[]

  policy        Policy?
  proposal      Proposal?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  version       Int             @default(1)

  @@index([quotationCode])
  @@index([status])
  @@map("quotations")
}

model QuotationVersion {
  id             String    @id @default(uuid())
  quotationId    String
  quotation      Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  versionNumber  Int
  sumInsured     Decimal
  basePremium    Decimal
  gstAmount      Decimal
  totalPremium   Decimal
  discountAmount Decimal
  metadata       Json?

  createdById    String?
  createdBy      User?     @relation("QuotationVersionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt      DateTime  @default(now())

  @@index([quotationId])
  @@map("quotation_versions")
}

model QuotationAddon {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  addonCode   String
  addonName   String
  premium     Decimal
  description String?

  @@index([quotationId])
  @@map("quotation_addons")
}

model QuotationDiscount {
  id           String    @id @default(uuid())
  quotationId  String
  quotation    Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  discountType String
  percentage   Decimal?
  amount       Decimal
  description  String?

  @@index([quotationId])
  @@map("quotation_discounts")
}

model QuotationComparison {
  id             String    @id @default(uuid())
  comparisonCode String    @unique
  leadId         String?
  metadata       Json?
  
  createdAt      DateTime  @default(now())

  @@index([comparisonCode])
  @@map("quotation_comparisons")
}

model QuotationHistory {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  status      String
  comments    String?
  
  createdById String?
  createdBy   User?     @relation("QuotationHistoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now())

  @@index([quotationId])
  @@map("quotation_histories")
}

model QuotationDocument {
  id           String    @id @default(uuid())
  quotationId  String
  quotation    Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  documentType String
  fileKey      String
  fileName     String
  fileSize     Int
  
  createdAt    DateTime  @default(now())

  @@index([quotationId])
  @@map("quotation_documents")
}

//////////////////////////////////////////////////////////
// POLICIES
//////////////////////////////////////////////////////////

model Policy {
  id             String       @id @default(uuid())
  policyNumber   String       @unique
  status         PolicyStatus @default(ACTIVE)

  quotationId    String       @unique
  quotation      Quotation    @relation(fields: [quotationId], references: [id])

  contactId      String
  contact        Contact      @relation(fields: [contactId], references: [id])

  accountId      String?
  account        Account?     @relation(fields: [accountId], references: [id])

  premiumAmount  Decimal
  effectiveDate  DateTime
  expiryDate     DateTime

  createdById    String?
  updatedById    String?
  createdBy      User?        @relation("PolicyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?        @relation("PolicyUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  members        PolicyMember[]
  nominees       PolicyNominee[]
  renewals       PolicyRenewal[]
  payments       PolicyPayment[]
  documents      PolicyDocument[]
  histories      PolicyHistory[]
  claims         Claim[]
  renewalTasks   RenewalTask[]
  proposalId     String?      @unique
  proposal       Proposal?    @relation(fields: [proposalId], references: [id])
  endorsements   Endorsement[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  version        Int          @default(1)

  @@index([policyNumber])
  @@index([status])
  @@index([contactId])
  @@index([expiryDate])
  @@index([accountId])
  @@index([deletedAt])
  @@map("policies")
}

model PolicyMember {
  id           String   @id @default(uuid())
  policyId     String
  policy       Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  relation     String
  dateOfBirth  DateTime

  @@index([policyId])
  @@map("policy_members")
}

model PolicyNominee {
  id           String   @id @default(uuid())
  policyId     String
  policy       Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  relation     String
  percentage   Decimal

  @@index([policyId])
  @@map("policy_nominees")
}

model PolicyRenewal {
  id             String    @id @default(uuid())
  policyId       String
  policy         Policy    @relation(fields: [policyId], references: [id], onDelete: Cascade)
  renewalNumber  Int
  previousExpiry DateTime
  newExpiry      DateTime
  premiumAmount  Decimal
  createdAt      DateTime  @default(now())

  @@index([policyId])
  @@unique([policyId, renewalNumber])
  @@map("policy_renewals")
}

model PolicyPayment {
  id            String        @id @default(uuid())
  policyId      String
  policy        Policy        @relation(fields: [policyId], references: [id], onDelete: Cascade)
  amount        Decimal
  paymentDate   DateTime      @default(now())
  transactionId String        @unique
  paymentMethod String
  status        PaymentStatus @default(SUCCESS)

  @@index([policyId])
  @@map("policy_payments")
}

model PolicyDocument {
  id           String   @id @default(uuid())
  policyId     String
  policy       Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  documentType String
  fileKey      String
  fileName     String
  fileSize     Int
  createdAt    DateTime @default(now())

  @@index([policyId])
  @@map("policy_documents")
}

model PolicyHistory {
  id          String   @id @default(uuid())
  policyId    String
  policy      Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  status      String
  comments    String?
  
  createdById String?
  createdBy   User?    @relation("PolicyHistoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())

  @@index([policyId])
  @@map("policy_histories")
}

//////////////////////////////////////////////////////////
// CLAIMS MANAGEMENT ENGINE
//////////////////////////////////////////////////////////

enum ClaimStatus {
  REPORTED
  REGISTERED
  SURVEYOR_ASSIGNED
  UNDER_ASSESSMENT
  APPROVED
  REJECTED
  PAYMENT_PENDING
  SETTLED
  CLOSED
}

enum ReserveType {
  INITIAL
  ADJUSTED
  RELEASED
}

model Claim {
  id             String          @id @default(uuid())
  claimNumber    String          @unique
  status         ClaimStatus     @default(REPORTED)
  
  policyId       String
  policy         Policy          @relation(fields: [policyId], references: [id])
  
  contactId      String
  contact        Contact         @relation(fields: [contactId], references: [id])
  
  accountId      String?
  account        Account?        @relation(fields: [accountId], references: [id])
  
  incidentDate   DateTime
  reportedDate   DateTime        @default(now())
  description    String
  claimAmount    Decimal
  approvedAmount Decimal?
  
  surveyorName   String?
  surveyorDetails String?

  createdById    String?
  updatedById    String?
  createdBy      User?           @relation("ClaimCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?           @relation("ClaimUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  documents      ClaimDocument[]
  assessments    ClaimAssessment[]
  payments       ClaimPayment[]
  reserves       ClaimReserve[]
  histories      ClaimHistory[]
  communications ClaimCommunication[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  version        Int             @default(1)

  @@index([claimNumber])
  @@index([status])
  @@index([policyId])
  @@index([contactId])
  @@index([incidentDate])
  @@index([accountId])
  @@map("claims")
}

model ClaimDocument {
  id           String    @id @default(uuid())
  claimId      String
  claim        Claim     @relation(fields: [claimId], references: [id], onDelete: Cascade)
  documentType String
  fileKey      String
  fileName     String
  fileSize     Int
  uploadedById String?
  
  createdAt    DateTime  @default(now())

  @@index([claimId])
  @@map("claim_documents")
}

model ClaimAssessment {
  id             String    @id @default(uuid())
  claimId        String
  claim          Claim     @relation(fields: [claimId], references: [id], onDelete: Cascade)
  assessorId     String?
  assessor       User?     @relation("ClaimAssessor", fields: [assessorId], references: [id], onDelete: SetNull)
  assessmentDate DateTime  @default(now())
  findings       String
  estimatedLoss  Decimal
  approvedAmount Decimal
  status         String    // e.g. PENDING, COMPLETED, REJECTED
  
  createdAt      DateTime  @default(now())

  @@index([claimId])
  @@map("claim_assessments")
}

model ClaimPayment {
  id             String        @id @default(uuid())
  claimId        String
  claim          Claim         @relation(fields: [claimId], references: [id], onDelete: Cascade)
  amount         Decimal
  paymentDate    DateTime      @default(now())
  transactionId  String        @unique
  paymentMethod  String
  status         PaymentStatus @default(PENDING)
  recipientDetails String
  
  createdAt      DateTime      @default(now())

  @@index([claimId])
  @@map("claim_payments")
}

model ClaimReserve {
  id           String      @id @default(uuid())
  claimId      String
  claim        Claim       @relation(fields: [claimId], references: [id], onDelete: Cascade)
  amount       Decimal
  type         ReserveType @default(INITIAL)
  comments     String?
  createdById  String?
  createdBy    User?       @relation("ClaimReserveCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  
  createdAt    DateTime    @default(now())

  @@index([claimId])
  @@map("claim_reserves")
}

model ClaimHistory {
  id          String      @id @default(uuid())
  claimId     String
  claim       Claim       @relation(fields: [claimId], references: [id], onDelete: Cascade)
  status      ClaimStatus
  action      String
  comments    String?
  createdById String?
  createdBy   User?       @relation("ClaimHistoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  
  createdAt   DateTime    @default(now())

  @@index([claimId])
  @@map("claim_histories")
}

model ClaimCommunication {
  id          String               @id @default(uuid())
  claimId     String
  claim       Claim                @relation(fields: [claimId], references: [id], onDelete: Cascade)
  senderId    String?
  sender      User?                @relation("ClaimCommunicationSender", fields: [senderId], references: [id], onDelete: SetNull)
  recipient   String
  channel     CommunicationChannel
  subject     String?
  body        String
  sentAt      DateTime             @default(now())

  @@index([claimId])
  @@map("claim_communications")
}

//////////////////////////////////////////////////////////
// NOTIFICATIONS & RENEWALS
//////////////////////////////////////////////////////////

enum NotificationType {
  SYSTEM
  LEAD_ASSIGNED
  LEAD_UPDATED
  FOLLOW_UP_DUE
  QUOTATION_CREATED
  QUOTATION_APPROVED
  QUOTATION_REJECTED
  POLICY_ISSUED
  POLICY_CANCELLED
  POLICY_RENEWAL_45
  POLICY_RENEWAL_30
  POLICY_RENEWAL_20
  CLAIM_REGISTERED
  CLAIM_ASSIGNED
  CLAIM_APPROVED
  CLAIM_SETTLED
  DOCUMENT_UPLOADED
  ENDORSEMENT_APPROVED
}

enum NotificationPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum RenewalTaskStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Notification {
  id          String               @id @default(uuid())
  title       String
  message     String
  type        NotificationType
  priority    NotificationPriority @default(MEDIUM)
  userId      String
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityId    String?
  entityType  String?
  actionUrl   String?
  icon        String?
  color       String?
  expiresAt   DateTime?
  isRead      Boolean              @default(false)
  readAt      DateTime?
  createdAt   DateTime             @default(now())
  histories   NotificationHistory[]

  @@index([userId])
  @@index([isRead])
  @@index([userId, isRead])
  @@map("notifications")
}

model NotificationTemplate {
  id        String           @id @default(uuid())
  name      String           @unique
  type      NotificationType
  channel   String           @default("IN_APP")
  subject   String?
  body      String
  variables Json?
  active    Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@map("notification_templates")
}

model NotificationPreference {
  id         String  @id @default(uuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  inApp      Boolean @default(true)
  email      Boolean @default(false)
  sms        Boolean @default(false)
  whatsapp   Boolean @default(false)
  renewals   Boolean @default(true)
  claims     Boolean @default(true)
  policies   Boolean @default(true)
  leads      Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("notification_preferences")
}

model NotificationHistory {
  id             String             @id @default(uuid())
  notificationId String
  notification   Notification       @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  status         NotificationStatus @default(SENT)
  channel        String             @default("IN_APP")
  sentAt         DateTime           @default(now())
  failureReason  String?

  @@index([notificationId])
  @@map("notification_histories")
}

model RenewalTask {
  id        String            @id @default(uuid())
  policyId  String
  policy    Policy            @relation(fields: [policyId], references: [id], onDelete: Cascade)
  agentId   String
  agent     User              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  dueDate   DateTime
  status    RenewalTaskStatus @default(PENDING)
  priority  NotificationPriority @default(MEDIUM)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([policyId])
  @@index([agentId])
  @@index([status])
  @@index([dueDate])
  @@index([agentId, status])
  @@map("renewal_tasks")
}

//////////////////////////////////////////////////////////
// SECURE DOCUMENT MANAGEMENT
//////////////////////////////////////////////////////////

enum DocumentVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum DocumentStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum DocumentAccessAction {
  VIEW
  DOWNLOAD
  DELETE
  RESTORE
}

model Document {
  id                 String                     @id @default(uuid())
  documentNumber     String                     @unique
  name               String
  originalFileName   String
  mimeType           String
  size               Int
  storageKey         String
  storageProvider    String
  hash               String
  entityType         String
  entityId           String
  uploadedById       String
  uploadedBy         User                       @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])
  status             DocumentStatus             @default(ACTIVE)
  version            Int                        @default(1)
  verificationStatus DocumentVerificationStatus @default(PENDING)
  expiryDate         DateTime?
  tags               String[]                   @default([])
  metadata           Json?
  
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  deletedAt          DateTime?

  versions           DocumentVersion[]
  accessLogs         DocumentAccessLog[]
  proposalDocuments   ProposalDocument[]
  endorsementDocuments EndorsementDocument[]

  @@index([entityType, entityId])
  @@index([uploadedById])
  @@index([documentNumber])
  @@map("documents")
}

model DocumentVersion {
  id               String   @id @default(uuid())
  documentId       String
  document         Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version          Int
  storageKey       String
  originalFileName String
  size             Int
  hash             String
  uploadedAt       DateTime @default(now())

  @@index([documentId])
  @@unique([documentId, version])
  @@map("document_versions")
}

model DocumentAccessLog {
  id         String               @id @default(uuid())
  documentId String
  document   Document             @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     DocumentAccessAction
  ipAddress  String?
  createdAt  DateTime             @default(now())

  @@index([documentId])
  @@index([userId])
  @@map("document_access_logs")
}

//////////////////////////////////////////////////////////
// MOTOR ADMINISTRATION & RATING RULES
//////////////////////////////////////////////////////////

enum VehicleType {
  TWO_WHEELER
  FOUR_WHEELER
  COMMERCIAL
}

enum FuelType {
  PETROL
  DIESEL
  CNG
  ELECTRIC
  HYBRID
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
}

enum RatingRuleType {
  BASE_RATE
  AGE_LOADING
  NCB_DISCOUNT
  OD_DISCOUNT
  ADDON_RATE
  TAX_RATE
}

enum ProductType {
  THIRD_PARTY
  COMPREHENSIVE
  ZERO_DEP
  OWN_DAMAGE
  COMMERCIAL
}

model VehicleManufacturer {
  id        String         @id @default(uuid())
  name      String         @unique
  code      String         @unique
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  models    VehicleModel[]

  @@map("vehicle_manufacturers")
}

model VehicleModel {
  id             String              @id @default(uuid())
  manufacturerId String
  manufacturer   VehicleManufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
  name           String
  code           String              @unique
  vehicleType    VehicleType         @default(FOUR_WHEELER)
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  variants       VehicleVariant[]

  @@index([manufacturerId])
  @@map("vehicle_models")
}

model VehicleVariant {
  id               String           @id @default(uuid())
  modelId          String
  model            VehicleModel     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  name             String
  code             String           @unique
  fuelType         FuelType         @default(PETROL)
  transmissionType TransmissionType @default(MANUAL)
  engineCapacity   Int
  exShowroomPrice  Decimal
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([modelId])
  @@map("vehicle_variants")
}

model Insurer {
  id             String       @id @default(uuid())
  name           String       @unique
  code           String       @unique
  rating         Decimal?
  isActive       Boolean      @default(true)
  contactDetails Json?
  logoUrl        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  rules          RatingRule[]

  @@map("insurers")
}

model Product {
  id                  String       @id @default(uuid())
  name                String
  code                String       @unique
  type                ProductType
  baseCommissionRate  Decimal
  description         String?
  isActive            Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  rules               RatingRule[]

  @@map("products")
}

model RatingRule {
  id                  String         @id @default(uuid())
  productId           String
  product             Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  insurerId           String
  insurer             Insurer        @relation(fields: [insurerId], references: [id], onDelete: Cascade)
  ruleName            String
  ruleType            RatingRuleType
  eligibilityCriteria Json
  formulaOrRate       Json
  priority            Int            @default(0)
  isActive            Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([productId])
  @@index([insurerId])
  @@index([productId, insurerId, isActive])
  @@map("rating_rules")
}

//////////////////////////////////////////////////////////
// PROPOSALS & UNDERWRITING
//////////////////////////////////////////////////////////

enum ProposalStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  DOCUMENT_PENDING
  APPROVED
  REJECTED
  POLICY_ISSUED
}

model Proposal {
  id             String             @id @default(uuid())
  proposalNumber String             @unique
  quotationId    String             @unique
  quotation      Quotation          @relation(fields: [quotationId], references: [id])
  contactId      String
  contact        Contact            @relation(fields: [contactId], references: [id])
  status         ProposalStatus     @default(DRAFT)
  remarks        String?
  submittedById  String
  submittedBy    User               @relation("ProposalSubmittedBy", fields: [submittedById], references: [id])
  reviewedById   String?
  reviewedBy     User?              @relation("ProposalReviewedBy", fields: [reviewedById], references: [id])
  approvedById   String?
  approvedBy     User?              @relation("ProposalApprovedBy", fields: [approvedById], references: [id])
  rejectedReason String?
  submittedAt    DateTime?
  reviewedAt     DateTime?
  approvedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  version        Int                @default(1)

  documents      ProposalDocument[]
  histories      ProposalHistory[]
  policy         Policy?

  @@index([quotationId])
  @@index([contactId])
  @@index([submittedById])
  @@map("proposals")
}

model ProposalDocument {
  id         String   @id @default(uuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  documentId String?
  document   Document? @relation(fields: [documentId], references: [id])
  mandatory  Boolean  @default(true)
  verified   Boolean  @default(false)
  remarks    String?

  @@index([proposalId])
  @@map("proposal_documents")
}

model ProposalHistory {
  id            String         @id @default(uuid())
  proposalId    String
  proposal      Proposal       @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  status        ProposalStatus
  comments      String?
  performedById String
  performedBy   User           @relation(fields: [performedById], references: [id])
  createdAt     DateTime       @default(now())

  @@index([proposalId])
  @@index([performedById])
  @@map("proposal_histories")
}

//////////////////////////////////////////////////////////
// ENDORSEMENTS & ALTERATIONS
//////////////////////////////////////////////////////////

enum EndorsementType {
  ADDRESS_CHANGE
  OWNER_TRANSFER
  NOMINEE_CHANGE
}

enum EndorsementStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  COMPLETED
}

model Endorsement {
  id                String            @id @default(uuid())
  endorsementNumber String            @unique
  policyId          String
  policy            Policy            @relation(fields: [policyId], references: [id], onDelete: Cascade)
  type              EndorsementType
  status            EndorsementStatus @default(REQUESTED)
  requestedById     String
  requestedBy       User              @relation("EndorsementRequestedBy", fields: [requestedById], references: [id])
  approvedById      String?
  approvedBy        User?             @relation("EndorsementApprovedBy", fields: [approvedById], references: [id])
  reason            String
  effectiveDate     DateTime          @default(now())
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  documents         EndorsementDocument[]
  histories         EndorsementHistory[]

  @@index([policyId])
  @@index([requestedById])
  @@map("endorsements")
}

model EndorsementDocument {
  id            String      @id @default(uuid())
  endorsementId String
  endorsement   Endorsement @relation(fields: [endorsementId], references: [id], onDelete: Cascade)
  documentId    String
  document      Document    @relation(fields: [documentId], references: [id])

  @@index([endorsementId])
  @@index([documentId])
  @@map("endorsement_documents")
}

model EndorsementHistory {
  id            String            @id @default(uuid())
  endorsementId String
  endorsement   Endorsement       @relation(fields: [endorsementId], references: [id], onDelete: Cascade)
  status        EndorsementStatus
  comments      String?
  performedById String
  performedBy   User              @relation(fields: [performedById], references: [id])
  createdAt     DateTime          @default(now())

  @@index([endorsementId])
  @@index([performedById])
  @@map("endorsement_histories")
}

//////////////////////////////////////////////////////////
// REPORTING, BI & DATA WAREHOUSE
//////////////////////////////////////////////////////////

enum ReportRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum KpiUnit {
  PERCENTAGE
  CURRENCY
  COUNT
  RATIO
  DAYS
}

enum ReportCategory {
  SALES
  UNDERWRITING
  CLAIMS
  POLICY
  CRM
  FINANCE
  AUDIT
  CUSTOM
}

model SavedReport {
  id          String         @id @default(uuid())
  name        String
  description String?
  category    ReportCategory
  dataSource  String         // contacts | leads | policies | claims | renewals | revenue
  columns     Json           // Array of column definition objects
  filters     Json           // Array of filter definition objects
  sortBy      String?
  sortDir     String?        @default("asc")
  isBuiltIn   Boolean        @default(false)
  isActive    Boolean        @default(true)

  createdById String
  createdBy   User           @relation("SavedReportCreatedBy", fields: [createdById], references: [id])

  runs        ReportRun[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([createdById])
  @@index([category])
  @@map("saved_reports")
}

model ReportRun {
  id            String          @id @default(uuid())
  savedReportId String
  savedReport   SavedReport     @relation(fields: [savedReportId], references: [id], onDelete: Cascade)
  status        ReportRunStatus @default(PENDING)
  rowCount      Int?
  exportPath    String?
  errorMessage  String?
  appliedFilters Json?

  triggeredById String?
  triggeredBy   User?   @relation("ReportRunTriggeredBy", fields: [triggeredById], references: [id], onDelete: SetNull)

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([savedReportId])
  @@index([status])
  @@map("report_runs")
}

model KpiDefinition {
  id          String   @id @default(uuid())
  name        String
  key         String   @unique
  description String?
  formula     String   // e.g. "policies_issued / leads_created * 100"
  category    String   // revenue | sales | claims | renewals | operations
  unit        KpiUnit  @default(COUNT)
  isActive    Boolean  @default(true)
  displayOrder Int     @default(0)

  createdById String?
  createdBy   User?   @relation("KpiDefinitionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@map("kpi_definitions")
}

enum ReportModule {
  LEADS
  CONTACTS
  QUOTATIONS
  POLICIES
  CLAIMS
  REPORTS
}

enum ReportType {
  TABULAR
  SUMMARY
  CHART
  MATRIX
}

enum ReportStatus {
  ACTIVE
  INACTIVE
}

enum ReportFilterOperator {
  EQUALS
  CONTAINS
  STARTS_WITH
  ENDS_WITH
  BETWEEN
  GREATER_THAN
  LESS_THAN
  IN
  NOT_IN
  NULL
  NOT_NULL
}

enum ReportExecutionStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum ReportScheduleFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

model Report {
  id             String         @id @default(uuid())
  name           String
  code           String         @unique
  description    String?
  category       ReportCategory
  module         ReportModule
  type           ReportType     @default(TABULAR)
  status         ReportStatus   @default(ACTIVE)
  version        Int            @default(1)
  isSystem       Boolean        @default(false)
  shared         Boolean        @default(false)
  
  parentId       String?
  parent         Report?        @relation("ReportHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children       Report[]       @relation("ReportHierarchy")

  // Statistics
  executionCount  Int           @default(0)
  lastExecutedAt  DateTime?
  averageDuration Float         @default(0.0)

  createdById    String?
  createdBy      User?          @relation("ReportCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById    String?
  updatedBy      User?          @relation("ReportUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  columns        ReportColumn[]
  filters        ReportFilter[]
  executions     ReportExecution[]
  schedules      ReportSchedule[]
  savedFilters   SavedFilter[]
  favorites      FavoriteReport[]

  @@map("reports")
}

model ReportColumn {
  id            String   @id @default(uuid())
  reportId      String
  report        Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  field         String
  label         String
  type          String
  sortable      Boolean  @default(true)
  filterable    Boolean  @default(true)
  visible       Boolean  @default(true)
  order         Int      @default(0)
  configuration Json?

  @@map("report_columns")
}

model ReportFilter {
  id           String               @id @default(uuid())
  reportId     String
  report       Report               @relation(fields: [reportId], references: [id], onDelete: Cascade)
  field        String
  operator     ReportFilterOperator
  defaultValue Json?
  required     Boolean              @default(false)

  @@map("report_filters")
}

model ReportExecution {
  id            String                @id @default(uuid())
  reportId      String
  report        Report                @relation(fields: [reportId], references: [id], onDelete: Cascade)
  requestedById String?
  requestedBy   User?                 @relation("ReportExecutionRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  status        ReportExecutionStatus
  startedAt     DateTime              @default(now())
  completedAt   DateTime?
  duration      Int?
  filePath      String?
  recordCount   Int                   @default(0)
  parameters    Json?

  @@map("report_executions")
}

model ReportSchedule {
  id             String                  @id @default(uuid())
  reportId       String
  report         Report                  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  cronExpression String
  frequency      ReportScheduleFrequency
  timezone       String                  @default("UTC")
  active         Boolean                 @default(true)
  nextRun        DateTime?

  @@map("report_schedules")
}

model SavedFilter {
  id          String   @id @default(uuid())
  name        String
  reportId    String
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filters     Json     // key-value pair of filter values passed by user
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, name, reportId])
  @@map("saved_report_filters")
}

model FavoriteReport {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, reportId])
  @@map("favorite_reports")
}

enum WorkflowModule {
  LEADS
  PROPOSALS
  ENDORSEMENTS
  POLICIES
  CLAIMS
  QUOTATIONS
}

enum WorkflowEntityType {
  LEAD
  PROPOSAL
  POLICY
  ENDORSEMENT
  CLAIM
  QUOTATION
}

enum WorkflowApprovalType {
  ANY
  ALL
  SEQUENTIAL
}

model Workflow {
  id          String         @id @default(uuid())
  name        String
  code        String         @unique
  module      WorkflowModule
  description String?
  active      Boolean        @default(true)
  version     Int            @default(1)
  isSystem    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  states      WorkflowState[]
  transitions WorkflowTransition[]
  histories   WorkflowHistory[]

  @@map("workflows")
}

model WorkflowState {
  id               String               @id @default(uuid())
  workflowId       String
  workflow         Workflow             @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  name             String
  code             String
  isInitial        Boolean              @default(false)
  isTerminal       Boolean              @default(false)
  slaMinutes       Int?
  escalationRoleId String?
  
  incomingTransitions WorkflowTransition[] @relation("TransitionToState")
  outgoingTransitions WorkflowTransition[] @relation("TransitionFromState")
  assignments         WorkflowAssignment[]
  actions             WorkflowAction[]

  @@unique([workflowId, code])
  @@map("workflow_states")
}

model WorkflowTransition {
  id          String               @id @default(uuid())
  workflowId  String
  workflow    Workflow             @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromStateId String?
  fromState   WorkflowState?       @relation("TransitionFromState", fields: [fromStateId], references: [id], onDelete: SetNull)
  toStateId   String
  toState     WorkflowState        @relation("TransitionToState", fields: [toStateId], references: [id], onDelete: Cascade)
  name        String
  triggerType String               @default("MANUAL") // MANUAL, AUTOMATIC
  conditions  Json?                // { "logic": "AND", "rules": [...] }

  assignments WorkflowAssignment[]
  actions     WorkflowAction[]

  @@map("workflow_transitions")
}

model WorkflowAction {
  id           String              @id @default(uuid())
  stateId      String?
  state        WorkflowState?      @relation(fields: [stateId], references: [id], onDelete: Cascade)
  transitionId String?
  transition   WorkflowTransition? @relation(fields: [transitionId], references: [id], onDelete: Cascade)
  type         String              // NOTIFICATION, EVENT, DOCUMENT_GENERATION, AUDIT
  configuration Json?

  @@map("workflow_actions")
}

model WorkflowAssignment {
  id           String              @id @default(uuid())
  stateId      String?
  state        WorkflowState?      @relation(fields: [stateId], references: [id], onDelete: Cascade)
  transitionId String?
  transition   WorkflowTransition? @relation(fields: [transitionId], references: [id], onDelete: Cascade)
  roleId       String?
  role         Role?               @relation(fields: [roleId], references: [id], onDelete: SetNull)
  userId       String?
  user         User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  departmentId String?
  branchId     String?
  order        Int                 @default(0)
  required     Boolean             @default(true)
  approvalType WorkflowApprovalType @default(ANY)

  @@map("workflow_assignments")
}

model WorkflowHistory {
  id              String             @id @default(uuid())
  workflowId      String
  workflow        Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowVersion Int
  entityId        String
  entityType      WorkflowEntityType
  fromStateId     String?
  toStateId       String
  performedById   String?
  performedBy     User?              @relation(fields: [performedById], references: [id], onDelete: SetNull)
  comments        String?
  duration        Int?               // In seconds
  result          Json?
  variables       Json?
  createdAt       DateTime           @default(now())

  @@map("workflow_histories")
}



enum JobType {
  NOTIFICATION
  RENEWAL
  REPORT
  WORKFLOW
  DOCUMENT
  AUDIT
  SEARCH
  EMAIL
  SMS
  WHATSAPP
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  RETRYING
  DELAYED
}

model BackgroundJob {
  id            String    @id @default(uuid())
  queue         String
  jobId         String?   @unique
  type          JobType
  status        JobStatus @default(QUEUED)
  payload       Json?
  attempts      Int       @default(0)
  maxAttempts   Int       @default(3)
  startedAt     DateTime?
  completedAt   DateTime?
  error         String?   @db.Text
  createdBy     String?
  correlationId String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([queue, status])
  @@index([type])
  @@index([jobId])
}

// ==========================================
// ORGANIZATION MANAGEMENT
// Hierarchy: Company -> Region -> Zone -> Branch -> Department -> Team
// ==========================================

model Company {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  logoUrl     String?
  address     String?
  taxId       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  regions     Region[]
}

model Region {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  code        String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  zones       Zone[]
}

model Zone {
  id          String   @id @default(uuid())
  regionId    String
  name        String
  code        String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  region      Region   @relation(fields: [regionId], references: [id], onDelete: Restrict)
  branches    Branch[]
}

model Branch {
  id          String   @id @default(uuid())
  zoneId      String
  name        String
  code        String   @unique
  address     String?
  city        String?
  state       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  zone        Zone     @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  departments Department[]
  users       User[]
}

model Department {
  id          String   @id @default(uuid())
  branchId    String
  name        String
  code        String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  teams       Team[]
  users       User[]

  @@unique([branchId, code])
}

model Team {
  id          String   @id @default(uuid())
  departmentId String
  name        String
  code        String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  department  Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  users       User[]

  @@unique([departmentId, code])
}

// ==========================================
// SYSTEM CONFIGURATION & FEATURE FLAGS
// ==========================================

model SystemConfig {
  key         String   @id
  value       String   // JSON stringified value or scalar
  valueType   String   // 'STRING', 'NUMBER', 'BOOLEAN', 'JSON'
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeatureFlag {
  key         String   @id
  isEnabled   Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// NUMBERING ENGINE
// ==========================================

model NumberingFormat {
  entityType  String   @id // e.g. 'POLICY', 'CLAIM', 'LEAD'
  prefix      String
  format      String   // e.g. '{PREFIX}-{YYYY}-{MM}-{SEQUENCE}'
  padding     Int      @default(6) // e.g. 6 means 000001
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NumberingSequence {
  entityType  String
  year        Int
  month       Int
  sequence    Int      @default(0)
  
  @@id([entityType, year, month])
}

// ==========================================
// LOOKUP FRAMEWORK (Hierarchical)
// ==========================================

model LookupCategory {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  values      LookupValue[]
}

model LookupValue {
  id          String   @id @default(uuid())
  categoryId  String
  parentId    String?
  code        String
  name        String
  description String?
  orderIndex  Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    LookupCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  parent      LookupValue?   @relation("LookupHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children    LookupValue[]  @relation("LookupHierarchy")

  @@unique([categoryId, code])
}

// ==========================================
// BUSINESS CALENDAR
// ==========================================

model Holiday {
  id          String   @id @default(uuid())
  date        DateTime
  name        String
  isGlobal    Boolean  @default(true)
  branchId    String?  // If not global, applies to specific branch
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, branchId])
}

model WorkingHours {
  id          String   @id @default(uuid())
  dayOfWeek   Int      // 0 = Sunday, 1 = Monday, etc.
  startTime   String   // '09:00'
  endTime     String   // '18:00'
  isWorkingDay Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([dayOfWeek])
}
// ==========================================
// LEAD INTELLIGENCE ENGINE (EPIC 14.2)
// ==========================================

model LeadScoreRule {
  id          String   @id @default(uuid())
  name        String
  description String?
  condition   String   // JSON string or expression (e.g., source == "WEBSITE")
  points      Int      // Points to add/subtract
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LeadScoreLog {
  id          String   @id @default(uuid())
  leadId      String
  ruleId      String
  points      Int
  createdAt   DateTime @default(now())

  @@index([leadId])
}

model AssignmentRule {
  id          String   @id @default(uuid())
  name        String
  description String?
  condition   String   // JSON string or expression (e.g., zipCode == "590001")
  queueId     String
  priority    Int      @default(0) // Higher priority rules evaluated first
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RoutingQueue {
  id          String   @id @default(uuid())
  name        String
  description String?
  strategy    String   // 'ROUND_ROBIN', 'LOAD_BALANCED', 'SKILL_BASED'
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     QueueMember[]
}

model QueueMember {
  id          String   @id @default(uuid())
  queueId     String
  userId      String
  isAvailable Boolean  @default(true) // For presence/status routing
  capacity    Int      @default(10)   // Max concurrent leads
  currentLoad Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  queue       RoutingQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([queueId, userId])
}

model SlaPolicy {
  id               String   @id @default(uuid())
  name             String
  description      String?
  targetEntity     String   // 'LEAD', 'CLAIM'
  priority         String?  // 'HIGH', 'MEDIUM', 'LOW'
  firstResponseMin Int?     // Minutes to first response
  resolutionMin    Int?     // Minutes to resolution
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SlaViolation {
  id          String   @id @default(uuid())
  entityType  String   // 'LEAD', 'CLAIM'
  entityId    String
  policyId    String
  breachType  String   // 'FIRST_RESPONSE', 'RESOLUTION'
  breachedAt  DateTime @default(now())
  isResolved  Boolean  @default(false)
  resolvedAt  DateTime?

  @@index([entityType, entityId])
}
// ==========================================
// FINANCE & ACCOUNTING (EPIC 15)
// ==========================================

model ChartOfAccount {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  type        String   // 'ASSET', 'LIABILITY', 'EQUITY', 'REVENUE', 'EXPENSE'
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  journalLines JournalLine[]
}

model JournalEntry {
  id          String   @id @default(uuid())
  entryNumber String   @unique
  date        DateTime
  description String
  referenceId String?  // ID of the invoice, receipt, etc.
  referenceType String? // 'INVOICE', 'RECEIPT', 'COMMISSION'
  status      String   @default("POSTED") // 'DRAFT', 'POSTED', 'VOIDED'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines       JournalLine[]

  @@index([date])
  @@index([referenceId, referenceType])
}

model JournalLine {
  id              String   @id @default(uuid())
  journalEntryId  String
  accountId       String
  debit           Decimal  @default(0) @db.Decimal(19, 4)
  credit          Decimal  @default(0) @db.Decimal(19, 4)
  description     String?
  createdAt       DateTime @default(now())

  journalEntry    JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account         ChartOfAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([journalEntryId])
  @@index([accountId])
}

model Invoice {
  id          String   @id @default(uuid())
  invoiceNum  String   @unique
  date        DateTime @default(now())
  dueDate     DateTime
  totalAmount Decimal  @db.Decimal(19, 4)
  status      String   @default("UNPAID") // 'UNPAID', 'PARTIAL', 'PAID', 'VOID'
  entityId    String   // Policy ID
  entityType  String   @default("POLICY")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  allocations PaymentAllocation[]

  @@index([status])
  @@index([entityId, entityType])
}

model Receipt {
  id          String   @id @default(uuid())
  receiptNum  String   @unique
  date        DateTime @default(now())
  amount      Decimal  @db.Decimal(19, 4)
  paymentMode String   // 'CASH', 'BANK_TRANSFER', 'CHEQUE', 'CARD'
  reference   String?  // Cheque No, UTR No
  status      String   @default("CLEARED") // 'PENDING', 'CLEARED', 'BOUNCED'
  customerId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  allocations PaymentAllocation[]

  @@index([customerId])
}

model PaymentAllocation {
  id          String   @id @default(uuid())
  receiptId   String
  invoiceId   String
  amount      Decimal  @db.Decimal(19, 4)
  createdAt   DateTime @default(now())

  receipt     Receipt @relation(fields: [receiptId], references: [id], onDelete: Restrict)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@index([receiptId])
  @@index([invoiceId])
}

model CommissionPlan {
  id          String   @id @default(uuid())
  name        String
  description String?
  rules       String   // JSON containing slab, product, tier logic
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Commission {
  id          String   @id @default(uuid())
  policyId    String
  userId      String   // Agent or Manager getting the commission
  roleTier    String   // 'AGENT', 'BRANCH_MANAGER', 'ZONAL_MANAGER'
  amount      Decimal  @db.Decimal(19, 4)
  status      String   @default("ACCRUED") // 'ACCRUED', 'REALIZED', 'PAID', 'CANCELLED'
  planId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])

  @@index([policyId])
  @@index([userId])
  @@index([status])
}

model Settlement {
  id          String   @id @default(uuid())
  batchNumber String   @unique
  date        DateTime @default(now())
  totalAmount Decimal  @db.Decimal(19, 4)
  status      String   @default("PENDING") // 'PENDING', 'APPROVED', 'PROCESSED'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
// ==========================================
// CUSTOMER EXPERIENCE & 360 (EPIC 16)
// ==========================================

model CustomerAnalytics {
  id                 String   @id @default(uuid())
  contactId          String   @unique
  lifetimePremium    Decimal  @default(0) @db.Decimal(19, 4)
  lifetimeClaims     Decimal  @default(0) @db.Decimal(19, 4)
  lifetimeValue      Decimal  @default(0) @db.Decimal(19, 4)
  
  renewalProbability Int      @default(0) // 0-100%
  customerRiskScore  Int      @default(0) // 0-100 (higher is riskier)
  crossSellScore     Int      @default(0) // 0-100 (propensity to buy more)
  healthScore        Int      @default(100) // 0-100
  churnProbability   Int      @default(0) // 0-100%

  activePolicies     Int      @default(0)
  expiredPolicies    Int      @default(0)
  claimRatio         Decimal  @default(0) @db.Decimal(5, 2) // Total claims / Total premium

  lastCalculatedAt   DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  contact            Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model CommunicationLog {
  id                 String   @id @default(uuid())
  channel            String   // 'EMAIL', 'SMS', 'WHATSAPP', 'CALL', 'PUSH'
  direction          String   // 'INBOUND', 'OUTBOUND'
  status             String   // 'SENT', 'DELIVERED', 'READ', 'FAILED'
  
  contactId          String
  entityType         String?  // 'LEAD', 'POLICY', 'CLAIM'
  entityId           String?
  
  provider           String?  // 'TWILIO', 'KARIX', 'AWS_SES'
  providerMessageId  String?
  templateId         String?

  subject            String?
  messagePreview     String?
  messageBody        String?  @db.Text

  sentAt             DateTime?
  deliveredAt        DateTime?
  readAt             DateTime?
  failedAt           DateTime?
  errorCode          String?
  correlationId      String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  contact            Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([entityId, entityType])
  @@index([providerMessageId])
}

model FamilyMember {
  id          String   @id @default(uuid())
  contactId   String
  firstName   String
  lastName    String
  relationship String  // 'SPOUSE', 'CHILD', 'PARENT'
  dateOfBirth DateTime?
  gender      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

model VehicleAsset {
  id              String   @id @default(uuid())
  contactId       String
  registrationNum String   @unique
  make            String
  model           String
  variant         String?
  year            Int
  engineNumber    String?
  chassisNumber   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}
// ==========================================
// BUSINESS INTELLIGENCE (EPIC 17)
// Data Warehouse & Dashboards
// ==========================================

// Dimensions
model DimBranch {
  id        String   @id // Copied from Branch
  name      String
  zone      String?
  region    String?
}

model DimAgent {
  id        String   @id // Copied from User
  name      String
  role      String
  branchId  String
}

model DimCustomer {
  id        String   @id // Copied from Contact
  name      String
  type      String
  city      String?
  state     String?
}

model DimProduct {
  id        String   @id
  name      String
  category  String
  insurer   String
}

model DimDate {
  dateId    String   @id // e.g. "2026-07-20"
  date      DateTime
  year      Int
  month     Int
  day       Int
  quarter   Int
  dayOfWeek Int
}

// Facts
model FactPolicy {
  id             String   @id // Policy ID
  dateId         String   // Connects to DimDate
  branchId       String
  agentId        String
  customerId     String
  productId      String
  premiumAmount  Decimal  @db.Decimal(19, 4)
  commissionAmt  Decimal  @db.Decimal(19, 4)
  status         String
  createdAt      DateTime @default(now())
}

model FactClaim {
  id             String   @id // Claim ID
  dateId         String
  policyId       String
  branchId       String
  customerId     String
  amountClaimed  Decimal  @db.Decimal(19, 4)
  amountSettled  Decimal  @db.Decimal(19, 4)
  status         String
  createdAt      DateTime @default(now())
}

model FactRevenue {
  id             String   @id // Receipt/Invoice ID
  dateId         String
  branchId       String
  agentId        String
  customerId     String
  amount         Decimal  @db.Decimal(19, 4)
  type           String   // 'PREMIUM', 'COMMISSION_REALIZED'
  createdAt      DateTime @default(now())
}

// Dashboards
model Dashboard {
  id          String   @id @default(uuid())
  name        String
  roleTarget  String   // 'CEO', 'BRANCH_MANAGER', 'AGENT'
  isActive    Boolean  @default(true)
  widgets     DashboardWidget[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Widget {
  id          String   @id @default(uuid())
  name        String
  type        String   // 'BAR', 'LINE', 'PIE', 'METRIC'
  config      String   @db.Text // JSON configuration
  dashboards  DashboardWidget[]
  createdAt   DateTime @default(now())
}

model DashboardWidget {
  dashboardId String
  widgetId    String
  x           Int
  y           Int
  w           Int
  h           Int

  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  widget      Widget    @relation(fields: [widgetId], references: [id], onDelete: Cascade)

  @@id([dashboardId, widgetId])
}

// Forecasts
model ForecastResult {
  id          String   @id @default(uuid())
  metric      String   // 'REVENUE', 'RENEWALS', 'LEADS'
  targetDate  DateTime // The future month/date being forecasted
  branchId    String?  // Optional, if forecasting per branch
  value       Decimal  @db.Decimal(19, 4)
  lowerBound  Decimal? @db.Decimal(19, 4)
  upperBound  Decimal? @db.Decimal(19, 4)
  modelUsed   String   // 'STATISTICAL_MA', 'XGBOOST'
  calculatedAt DateTime @default(now())
}
// ==========================================
// INTEGRATIONS (EPIC 19)
// Platform Integration & Webhooks
// ==========================================

model IntegrationProvider {
  id              String   @id @default(uuid())
  name            String   // e.g. 'Razorpay', 'Twilio'
  type            String   // 'SMS', 'EMAIL', 'PAYMENT', 'VEHICLE', 'OCR'
  status          String   @default("ACTIVE") // 'ACTIVE', 'INACTIVE'
  isPrimary       Boolean  @default(false)
  priority        Int      @default(1)
  config          String   @db.Text // JSON with encrypted credentials
  failureCount    Int      @default(0)
  successRate     Decimal? @db.Decimal(5, 2)
  averageLatency  Int?     // in ms
  lastHeartbeat   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WebhookAuditLog {
  id              String   @id @default(uuid())
  provider        String   // 'razorpay', 'twilio'
  providerEventId String   @unique // The ID sent by the provider for idempotency
  eventType       String
  payload         String   @db.Text
  status          String   @default("PROCESSED") // 'PROCESSED', 'FAILED', 'IGNORED'
  errorMessage    String?  @db.Text
  createdAt       DateTime @default(now())
}
