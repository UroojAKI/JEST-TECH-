    "@types/opossum": "^8.1.9",
    "@types/pdfmake": "^0.3.3",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "argon2": "^0.44.0",
    "axios": "^1.18.1",
    "bullmq": "^5.80.9",
    "cache-manager": "^7.2.9",
    "cache-manager-redis-store": "^3.0.1",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
